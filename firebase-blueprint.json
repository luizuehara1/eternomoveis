{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "discount": { "type": "number" },
        "description": { "type": "string" },
        "featured": { "type": "boolean" },
        "stock": { "type": "number" },
        "active": { "type": "boolean" },
        "tag": { "type": "string", "enum": ["Oferta", "Lançamento", "Mais Vendido", ""] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "description"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["novo", "em atendimento", "vendido", "cancelado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "items", "total", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user whitelist",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor"] }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Store configuration",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "shippingInfo": { "type": "string" }
      }
    },
    "Banner": {
      "title": "Banner",
      "description": "Promotional banner",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products collection"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders collection"
    },
    "/admins/{email}": {
      "schema": "Admin",
      "description": "Admins whitelist (indexed by email)"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Store settings"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Banners for the home page"
    }
  }
}
